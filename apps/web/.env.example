# Web Application Environment Variables

# API Configuration
# Public API URL (used in client-side code)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Server-side API URL (for server components and server actions)
API_URL=http://localhost:3001

# Internal API URL (for server-to-server calls in containerized environment)
# Use this when running in Docker/Kubernetes for internal communication
API_INTERNAL_URL=http://api:3001

# Optional: API authentication token
# NEXT_PUBLIC_API_TOKEN=your-token-here

# Environment
NEXT_PUBLIC_ENV=development

