{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": [
        "**/.env*"
    ],
    "pipeline": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                ".next/**"
            ],
            "cache": true
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "outputs": [],
            "cache": true
        },
        "test": {
            "outputs": [
                "coverage/**"
            ],
            "cache": true
        }
    }
}