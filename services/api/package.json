{
    "name": "@equitrack/api",
    "version": "0.1.0",
    "private": true,
    "description": "EquiTrack Pro API Server",
    "main": "dist/main.js",
    "scripts": {
        "dev": "nest start --watch",
        "build": "nest build",
        "start": "node dist/main",
        "lint": "eslint src --ext .ts",
        "test": "jest",
        "test:integration": "jest --config jest-integration.config.js",
        "test:integration:docker": "docker-compose -f docker-compose.test.yml up --abort-on-container-exit"
    },
    "dependencies": {
        "@nestjs/common": "^10.0.0",
        "@nestjs/core": "^10.0.0",
        "@nestjs/platform-express": "^10.0.0",
        "@nestjs/config": "^3.0.0",
        "@nestjs/swagger": "^7.0.0",
        "@nestjs/terminus": "^10.0.0",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^7.8.0",
        "class-validator": "^0.14.0",
        "class-transformer": "^0.5.0",
        "swagger-ui-express": "^5.0.0",
        "@equitrack/db": "workspace:*",
        "@equitrack/shared": "workspace:*"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.0.0",
        "@nestjs/testing": "^10.0.0",
        "@types/express": "^4.17.0",
        "@types/node": "^20.0.0",
        "typescript": "^5.0.0",
        "eslint": "^8.0.0",
        "jest": "^29.0.0",
        "@types/jest": "^29.0.0",
        "ts-jest": "^29.0.0",
        "ts-loader": "^9.0.0",
        "testcontainers": "^10.0.0",
        "uuid": "^9.0.0"
    }
}
