{
    "name": "@equitrack/db",
    "version": "0.1.0",
    "private": true,
    "description": "EquiTrack Pro Database Layer with Prisma ORM",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:migrate:deploy": "prisma migrate deploy",
        "db:studio": "prisma studio",
        "db:seed": "ts-node --esm prisma/seed.ts",
        "db:reset": "prisma migrate reset",
        "db:push": "prisma db push"
    },
    "dependencies": {
        "@prisma/client": "^5.0.0"
    },
    "devDependencies": {
        "prisma": "^5.0.0",
        "typescript": "^5.0.0",
        "@types/node": "^20.0.0",
        "ts-node": "^10.0.0",
        "dotenv": "^16.0.0"
    }
}